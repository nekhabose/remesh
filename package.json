{
  "name": "remesh-take-home",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "postinstall": "npm --workspace shared run build",
    "build": "npm-run-all build:shared build:server build:client",
    "build:shared": "npm --workspace shared run build",
    "build:server": "npm --workspace server run build",
    "build:client": "npm --workspace client run build",
    "test": "npm-run-all build:shared test:server test:client",
    "test:server": "npm --workspace server run test",
    "test:client": "npm --workspace client run test",
    "test:e2e": "npm run build && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "npm-run-all": "^4.1.5"
  }
}
